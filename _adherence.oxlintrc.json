{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/trading/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|full|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, full, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|action|padding|inset|interactive|as|bodyStyle|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, action, padding, inset, interactive, as, bodyStyle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FiredBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:fired|reason|style|key|ref|className|style|children)$/]",
        "message": "<FiredBadge> doesn't accept that prop. Declared props: fired, reason, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KillSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|onToggle|label|style|key|ref|className|style|children)$/]",
        "message": "<KillSwitch> doesn't accept that prop. Declared props: state, onToggle, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KillSwitch'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:ARMED|TRIPPED)$/]",
        "message": "<KillSwitch> state must be one of 'ARMED' | 'TRIPPED'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaDir|sub|tone|icon|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, delta, deltaDir, sub, tone, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<KpiCard> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|profit|loss)$/]",
        "message": "<KpiCard> tone must be one of 'neutral' | 'profit' | 'loss'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<ModePill> doesn't accept that prop. Declared props: mode, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModePill'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:LIVE|DRY-RUN)$/]",
        "message": "<ModePill> mode must be one of 'LIVE' | 'DRY-RUN'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:result|size|style|key|ref|className|style|children)$/]",
        "message": "<ResultBadge> doesn't accept that prop. Declared props: result, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultBadge'] > JSXAttribute[name.name='result'] > Literal[value!=/^(?:WIN|LOSS|OPEN|BE|BREAKEVEN)$/]",
        "message": "<ResultBadge> result must be one of 'WIN' | 'LOSS' | 'OPEN' | 'BE' | 'BREAKEVEN'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<ResultBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|size|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:live|firing|done|cancelled|open|profit|loss)$/]",
        "message": "<StatusDot> status must be one of 'live' | 'firing' | 'done' | 'cancelled' | 'open' | 'profit' | 'loss'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|style|key|ref|className|style|children)$/]",
        "message": "<TypeChip> doesn't accept that prop. Declared props: type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeChip'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:WATCH|ENTRY|PARTIAL|CLOSE)$/]",
        "message": "<TypeChip> type must be one of 'WATCH' | 'ENTRY' | 'PARTIAL' | 'CLOSE'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
